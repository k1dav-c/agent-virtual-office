# Docker Compose Environment Variables
# Copy this file to .env and fill in your actual values
#
# Note: Variables using SERVICE_* naming pattern are compatible with Coolify
# and will be auto-generated with random values when deployed on Coolify

# --- Auth0 Configuration ---
VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# --- PostgreSQL Configuration ---
# Coolify will auto-generate these values
SERVICE_USER_POSTGRES=postgres
SERVICE_PASSWORD_POSTGRES=
POSTGRES_DB=hasura

# --- Hasura Configuration ---
# Coolify will auto-generate admin secret
SERVICE_PASSWORD_HASURA_ADMIN=
HASURA_GRAPHQL_ENABLE_CONSOLE=true
HASURA_GRAPHQL_DEV_MODE=true
HASURA_ENDPOINT=http://hasura:8080/v1/graphql
# JWT Configuration (RS256 with Auth0 JWKS)
HASURA_GRAPHQL_JWT_SECRET={"type":"RS256","jwk_url":"https://your-auth0-domain.auth0.com/.well-known/jwks.json"}

# --- RabbitMQ Configuration ---
# Coolify will auto-generate these values
SERVICE_USER_RABBITMQ=admin
SERVICE_PASSWORD_RABBITMQ=
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/

# --- Frontend API URLs ---
# Update these based on your deployment environment
VITE_API_URL=http://localhost:8000 # no slash on the end
VITE_HASURA_ENDPOINT=http://localhost:8080/v1/graphql
